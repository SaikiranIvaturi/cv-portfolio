  "iconography": {
    "types": ["categorical", "functional"],
    "principles": [
      "Use consistent line weight",
      "Mix soft and hard forms; rounded joints and caps acceptable",
      "Use icons sparingly and at small sizes",
      "Categorical icons can use primary or secondary colors",
      "Functional icons use Navy, Dark Gray, or White"
    ],
    "incorrect": [
      "Do not use icons as part of a sentence",
      "Do not use icons in tints over colors; use White over color backgrounds",
      "Do not mix categorical and functional styles",
      "Do not use inconsistent stroke weights or multiple colors in a single icon"
    ],
    "sources": {
      "functional": "Material Design Icons (SVG/Webfont, CC-BY 4.0)"
    }
  },
  "dataVisualization": {
    "principles": [
      "Less is more; only essential data",
      "Use primary colors for simple data sets",
      "Add secondary colors for complex data sets",
      "Ensure adequate contrast between adjoining values",
      "Use simple, two-dimensional shapes and forms",
      "Use 1pt white rule to separate color segments when more than two colors"
    ],
    "incorrectUsage": [
      "Do not use random colors",
      "Do not color-code text to data segments",
      "Do not place charts over complex backgrounds",
      "Do not bury key information with lack of hierarchy"
    ]
  },
